# SQLite path (relative to backend/ or absolute)
DATABASE_URL=sqlite:///./data/starsleep.db

# Public base URL of this API (for Dify HTTP tool / ngrok)
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Optional: proxy chat to Dify Cloud
DIFY_API_BASE=https://api.dify.ai/v1
DIFY_API_KEY=
DIFY_APP_ID=

# HTTP tool defaults
ORDER_HTTP_TIMEOUT_SEC=5
ORDER_HTTP_MAX_RETRIES=2
ORDER_HTTP_RETRY_BACKOFF_SEC=0.4

# Local RAG knowledge root (relative to repo or absolute)
KNOWLEDGE_DIR=../knowledge-base
